rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Kept in step with the seniority helpers in firestore.rules.
    function isManagerOrAbove() {
      return request.auth != null
             && request.auth.token.role in ["Manager", "Admin", "SuperAdmin"];
    }

    // Job photos — authenticated users can upload and view; Manager+ can delete
    match /jobs/{jobId}/photos/{photoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isManagerOrAbove();
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
