RemoveHandler .php .php5 .php7 .php8
RemoveType application/x-httpd-php .php
PassengerEnabled on
PassengerBaseURI /
PassengerNodejs /home/polishst/nodevenv/pos.polishstation.lk/22/bin/node
PassengerAppRoot /home/polishst/pos.polishstation.lk
PassengerAppType node
PassengerStartupFile start.mjs
# Keep one Node process alive permanently. Without this, Passenger idles the
# app out after ~5 min without app-server traffic — which happens WHILE staff
# actively use the POS, because a loaded SPA talks straight to Firestore and
# sends the app server nothing. The next server call (login, add user, change
# PIN) then pays a ~20s cold start and times out as a LiteSpeed 408.
PassengerMinInstances 1
# Never shut down an idle instance (default is 300s). Together with
# MinInstances 1 this is the strongest .htaccess-level ask for "keep the worker
# alive forever" — so a login after days of no use lands on a warm process
# instead of paying the ~9s cold boot. NOTE: shared LiteSpeed hosting often
# caps or ignores these directives (the host owns the real idle timeout), which
# is why the external keep-warm ping to /healthz remains the reliable layer —
# this just removes idle-out wherever the host actually honors it.
PassengerPoolIdleTime 0
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml image/svg+xml
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  # HTML must always revalidate: asset filenames are content-hashed, so a
  # cached HTML page keeps referencing bundles that --delete removed from the
  # server on the next deploy — the "stuck tab that spins forever" failure.
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>