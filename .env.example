# Copy this file to .env and fill in the values.
# The VITE_* variables are safe to expose to the browser (Firebase API keys are public by design).
# The FIREBASE_* variables are secret — server-side Admin SDK only. Never expose them to the browser.

# ── Firebase Client SDK (browser) ────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ─────────────────────────────────────────
# From: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Sentry error reporting (optional, fill in when ready) ────────────────────
VITE_SENTRY_DSN=
SENTRY_DSN=
