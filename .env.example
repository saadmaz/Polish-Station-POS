# Copy this file to .env and fill in all values before running or deploying.

# ── Firebase Client (embedded in browser bundle — safe to expose) ─────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only — NEVER commit the real values) ───────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Sentry error reporting (optional) ────────────────────────────────────────
# Create a project at sentry.io → Settings → Projects → DSN
VITE_SENTRY_DSN=

# ── Super admin bootstrap (seeding only) ─────────────────────────────────────
# Run `npm run seed:admin` once to create the ADMIN account, then remove the PIN
# from .env. Login is username + PIN. The account is forced to change this PIN on
# first login, so treat it as a one-time bootstrap credential, not a password.
SUPERADMIN_USERNAME=ADMIN
SUPERADMIN_PIN=0011

# Original per-employee staff seeding (legacy). New installs use seed:admin above
# and create staff from Settings → Staff & Access. Deactivate these with
# `npm run reset:staff` after migrating. Each PIN must be exactly 4 digits.
STAFF_PIN_s1=
STAFF_PIN_s2=
STAFF_PIN_s3=
STAFF_PIN_s4=
STAFF_PIN_s5=
STAFF_PIN_s6=
STAFF_PIN_s7=
STAFF_PIN_s8=
STAFF_PIN_s9=
